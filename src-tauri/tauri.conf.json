{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vaelorium",
  "version": "0.3.0",
  "identifier": "com.vaelorium.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Vaelorium",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "tome",
          "vaelorium"
        ],
        "name": "Vaelorium Tome",
        "description": "Vaelorium worldbuilding Tome",
        "role": "Editor"
      }
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDMjY3ODI3N0JDMTkxMTgKUldRWWtjRjdKM2dtSEs5b09NS2dCZXYyL0lyNUVzdmxCdVl1Zlc5VENtRHJOcmxPTk0wcWJmYkcK",
      "endpoints": [
        "https://github.com/jsavko/Vaelorium/releases/latest/download/latest.json"
      ]
    }
  }
}
